{
  "manifest_version": 3,
  "name": "SWING Grading Assistant",
  "version": "1.0.0",
  "description": "SWING 과제 채점을 위한 티스토리 보호글 해제 매크로",

  "permissions": ["storage", "scripting"],
  "host_permissions": ["*://*.tistory.com/*"],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "티스토리 보호글 자동 입력",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.tistory.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
